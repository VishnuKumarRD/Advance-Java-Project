<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
<form action="addDeveloper">
<h2>--ADD DEVELOPER PAGE-</h2>
<br><hr><br>

<label for="name">ENTER EMPLOYEE NAME : </label>
<input type="text" id="name" placeholder="enter employee name" name="employeeName"><br><br>
<label for="mail">ENTER YOUR EMAIL : </label>
<input type="text" id="mail" placeholder="enter employee email" name="email"><br><br>
<label for="pwd">ENTER PASSWORD : </label>
<input type="text" id="pwd" placeholder="enter password" name="password"><br><br>
<label for="phno">ENTER YOUR PHONE NUMBER : </label>
<input type="text" id="phno" placeholder="enter phone number" name="phoneNumber"><br><br>
<label for="sal">ENTER SALARY : </label>
<input type="text" id="sal" placeholder="enter your salary" name="salary"><br><br>


<label for="hno">ENTER HOUSE NUMBER : </label>
<input type="text" id="hno" placeholder="enter house number" name="houseNumber"><br><br>
<label for="estreet">ENTER STREET : </label>
<input type="text" id="estreet" placeholder="enter street" name="street"><br><br>
<label for="ecity">ENTER CITY : </label>
<input type="text" id="ecity" placeholder="enter city" name="city"><br><br>
<label for="estate">ENTER STATE : </label>
<input type="text" id="estate" placeholder="enter state" name="state"><br><br>
<label for="ecountry">ENTER COUNTRY : </label>
<input type="text" id="ecountry" placeholder="enter country" name="country"><br><br>
<label for="epincode">ENTER PINCODE : </label>
<input type="text" id="epincode" placeholder="enter pincode" name="pincode"><br><br>
<input type="submit" value="REGISTER">

</form>
</body>
</html>